{
  "name": "Fasciculum Instrumentorum",
  "dockerComposeFile": "docker-compose.yml",
  "service": "app",
  "workspaceFolder": "/workspace",
  "containerEnv": {
    "PORT": "3101",
    "WEBSOCKET_PORT": "3101",
    "CORS_ORIGIN": "http://localhost:3100",
    "WEBSOCKET_CORS_ORIGIN": "http://localhost:3100",
    "ALLOWED_ORIGINS": "http://localhost:3100",
    "NEXTAUTH_URL": "http://localhost:3100",
    "NEXT_PUBLIC_API_URL": "http://localhost:3101",
    "NEXT_PUBLIC_WEBSOCKET_URL": "http://localhost:3101",
    "E2E_BASE_URL": "http://localhost:3100",
    "E2E_BACKEND_URL": "http://localhost:3101"
  },
  "features": {
    "ghcr.io/devcontainers/features/node:1": {
      "version": "25",
      "nodeGypDependencies": true,
      "installYarnUsingApt": false
    },
    "ghcr.io/devcontainers/features/docker-in-docker:2": {
      "version": "latest",
      "moby": true
    },
    "ghcr.io/devcontainers/features/git:1": {
      "version": "latest"
    },
    "ghcr.io/devcontainers/features/github-cli:1": {
      "version": "latest"
    }
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "dbaeumer.vscode-eslint",
        "esbenp.prettier-vscode",
        "editorconfig.editorconfig",
        "davidanson.vscode-markdownlint",
        "streetsidesoftware.code-spell-checker",
        // TypeScript / Node
        "ms-vscode.vscode-typescript-next",
        "christian-kohler.path-intellisense",
        "christian-kohler.npm-intellisense",
        // UI / styling
        "bradlc.vscode-tailwindcss",
        // Database / ORM
        "prisma.prisma",
        // Testing
        "vitest.explorer",
        "ms-playwright.playwright",
        "alexkrechik.cucumberautocomplete",
        // Containers & infrastructure
        "ms-azuretools.vscode-docker",
        "ms-kubernetes-tools.vscode-kubernetes-tools",
        // Data formats
        "redhat.vscode-yaml",
        "redhat.vscode-xml",
        // Git & GitHub
        "eamodio.gitlens",
        "github.vscode-pull-request-github",
        "github.vscode-github-actions",
        // Diagrams
        "mermaidchart.vscode-mermaid-chart",
        // Developer experience
        "usernamehw.errorlens",
        // AI
        "openai.chatgpt"
      ],
      "settings": {
        "editor.formatOnSave": true,
        "editor.defaultFormatter": "esbenp.prettier-vscode",
        "editor.codeActionsOnSave": {
          "source.fixAll.eslint": "explicit",
          "source.organizeImports": "explicit"
        },
        "typescript.tsdk": "node_modules/typescript/lib",
        "typescript.enablePromptUseWorkspaceTsdk": true,
        "eslint.workingDirectories": [{ "mode": "auto" }],
        "files.eol": "\n",
        "files.trimTrailingWhitespace": true,
        "files.insertFinalNewline": true
      }
    }
  },
  "postCreateCommand": "bash .devcontainer/post-create.sh",
  "forwardPorts": [3100, 3101, 5432, 6379],
  "portsAttributes": {
    "3100": {
      "label": "Frontend (Next.js)",
      "onAutoForward": "notify"
    },
    "3101": {
      "label": "Backend (Express)",
      "onAutoForward": "notify"
    },
    "5432": {
      "label": "PostgreSQL",
      "onAutoForward": "silent"
    },
    "6379": {
      "label": "Redis",
      "onAutoForward": "silent"
    }
  },
  "remoteUser": "node",
  "remoteEnv": {
    "OPENAI_API_KEY": "${localEnv:OPENAI_API_KEY}"
  }
}
